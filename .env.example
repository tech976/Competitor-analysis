# ─────────────────────────────────────────────────────────────
# AdGapIQ — environment variables
# Copy to `.env` and fill in real values. The app boots without keys;
# each integration stays gated until its key is set (graceful degradation).
# ─────────────────────────────────────────────────────────────

# ── Database (PostgreSQL + pgvector) ───────────────────────────
# Local: a Postgres with the `vector` extension. Or a free Neon/Supabase URL.
# pgvector powers the per-client learning memory; SQLite can't do vectors.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/adgapiq?schema=public"

# ── Apify (Meta Ad Library scraping) ───────────────────────────
# Personal API token: https://console.apify.com/account/integrations
APIFY_TOKEN=""
# Actor that scrapes the public Meta Ad Library. "owner~actor-name" format.
# Candidates: apify~facebook-ads-scraper · curious_coder~facebook-ads-library-scraper
APIFY_META_ADS_ACTOR="apify~facebook-ads-scraper"

# ── Anthropic (Claude — comparison + recommendations synthesis) ─
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ── Google Gemini (web-grounded research + video/image ad analysis) ─
# https://aistudio.google.com/apikey
# Add MULTIPLE keys (ideally from different Google accounts/projects) to spread
# the free-tier quota — they're rotated round-robin with automatic 429 failover.
GEMINI_API_KEY=""
GEMINI_API_KEY_2=""
GEMINI_API_KEY_3=""
# Use an always-current alias so new-project keys aren't gated to old versions.
GEMINI_MODEL="gemini-flash-latest"

# ── Pricing (cost estimates shown in the UI) — USD per 1,000 results ─
PRICE_PER_1K_ADS="3.40"

# ── Winning Ad Score tuning ────────────────────────────────────
# An ad live at/above this many days is treated as a strong "proven winner".
WINNER_DAYS_THRESHOLD="30"
